                "exec": [
                  "// Visualization Script",
                  "// Visualization Script",
                  "",
                  "const template = `",
                  "<style>",
                  "  body { font-family: Arial, sans-serif; padding: 16px; }",
                  "  h2 { color: #333; margin-bottom: 12px; }",
                  "  .no-tasks { color: #888; font-style: italic; font-size: 14px; }",
                  "  table { border-collapse: collapse; width: 100%; font-size: 13px; }",
                  "  th {",
                  "    background-color: #4a90d9;",
                  "    color: #fff;",
                  "    font-weight: bold;",
                  "    padding: 10px 14px;",
                  "    text-align: left;",
                  "    border: 1px solid #3a7bbf;",
                  "  }",
                  "  td {",
                  "    padding: 8px 14px;",
                  "    border: 1px solid #ddd;",
                  "    vertical-align: top;",
                  "  }",
                  "  tr:nth-child(even) td { background-color: #f2f7fd; }",
                  "  tr:nth-child(odd) td { background-color: #ffffff; }",
                  "  tr:hover td { background-color: #ddeeff; }",
                  "  .status-PENDING   { color: #e67e22; font-weight: bold; }",
                  "  .status-DONE      { color: #27ae60; font-weight: bold; }",
                  "  .status-IN_PROGRESS { color: #2980b9; font-weight: bold; }",
                  "</style>",
                  "",
                  "<h2>Tasks ({{count}} total)</h2>",
                  "",
                  "{{#if hasTasks}}",
                  "<table>",
                  "  <thead>",
                  "    <tr>",
                  "      <th>Title</th>",
                  "      <th>Description</th>",
                  "      <th>Status</th>",
                  "      <th>Due At</th>",
                  "      <th>Owner</th>",
                  "    </tr>",
                  "  </thead>",
                  "  <tbody>",
                  "    {{#each tasks}}",
                  "    <tr>",
                  "      <td>{{title}}</td>",
                  "      <td>{{description}}</td>",
                  "      <td><span class=\"status-{{status}}\">{{status}}</span></td>",
                  "      <td>{{due_at}}</td>",
                  "      <td>{{owner}}</td>",
                  "    </tr>",
                  "    {{/each}}",
                  "  </tbody>",
                  "</table>",
                  "{{else}}",
                  "<p class=\"no-tasks\">No tasks found.</p>",
                  "{{/if}}",
                  "`;",
                  "",
                  "function createPayload() {",
                  "  const res = pm.response.json();",
                  "  const tasks = res.tasks || [];",
                  "  return {",
                  "    count: res.count !== undefined ? res.count : tasks.length,",
                  "    hasTasks: tasks.length > 0,",
                  "    tasks: tasks.map(t => ({",
                  "      title:       t.title       || '',",
                  "      description: t.description || '',",
                  "      status:      t.status      || '',",
                  "      due_at:      t.due_at      || '',",
                  "      owner:       t.owner !== undefined ? String(t.owner) : ''",
                  "    }))",
                  "  };",
                  "}",
                  "",
                  "pm.visualizer.set(template, createPayload());",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
